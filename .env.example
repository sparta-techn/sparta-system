# =============================================================================
# SpartaFlow — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in.  `.env` (and `.env.*`) are git-ignored — NEVER
# commit real values.  Validate with:  bun run validate:env
#
# Two classes of variable, split by exposure:
#   • Server-side  → read at RUNTIME via process.env. Secrets live here.
#   • VITE_*       → INLINED into the browser bundle at BUILD time. Public only.
#
# Per-environment guidance (dev / staging / production) is in docs/ENVIRONMENT.md.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
# development | test | production   (drives log level, CSP, structured logs)
NODE_ENV=development
# Nitro/Node SSR server bind (containers use 0.0.0.0; host loopback uses 127.0.0.1)
HOST=127.0.0.1
PORT=3000

# --- Server-side Supabase (never exposed to the browser) --------------------
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Full RLS bypass — server-only. NEVER prefix with VITE_ and NEVER commit.
SUPABASE_SERVICE_ROLE_KEY=

# --- Server-side options ----------------------------------------------------
# Enforce Content-Security-Policy response headers (recommend "true" in prod).
ENFORCE_CSP=false
# Override log level: debug | info | warn | error  (default: debug in dev, info in prod)
LOG_LEVEL=
# Build/release identifiers for logs & error reports (usually set by CI).
RELEASE=
COMMIT_SHA=

# --- Client-side (VITE_-prefixed → inlined into the browser bundle) ---------
# Only public, publishable values belong here. Changing these needs a REBUILD.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Client-side options ----------------------------------------------------
# Browser log level: debug | info | warn | error  (optional)
VITE_LOG_LEVEL=
# Release identifiers surfaced in client error reports (usually set by CI).
VITE_RELEASE=
VITE_COMMIT_SHA=
