# Keep the build context small and never bake secrets or artifacts into layers.

# Secrets — never copy into an image layer
.env
.env.*
!.env.example
.dev.vars

# Dependencies & build output (rebuilt inside the image)
node_modules
.output
.nitro
.vinxi
.tanstack
dist
dist-ssr

# Cloudflare / Wrangler (not used by the Node/Docker path)
.wrangler

# VCS & CI
.git
.github
.gitignore

# Tests & reports
coverage
test-results
playwright-report
playwright/.cache
tests

# Docs & local tooling
docs
*.md
!README.md

# Editor / OS cruft
.vscode
.idea
.DS_Store
*.log
