# syntax=docker/dockerfile:1
# SpartaFlow — development image (Vite dev server with HMR).
# Source is bind-mounted by docker-compose.yml so edits hot-reload; this image
# only needs the dependencies pre-installed.

FROM oven/bun:1-alpine
WORKDIR /app

ENV NODE_ENV=development

# Install dependencies (cached until manifest changes).
COPY package.json bun.lock bunfig.toml ./
RUN bun install --frozen-lockfile

# Copy the rest for first run; compose bind-mounts over it for live editing.
COPY . .

EXPOSE 8080

# `--host 0.0.0.0` makes Vite reachable from outside the container.
# Port 8080 is published by compose; override PORT/args there if needed.
CMD ["bun", "run", "dev", "--", "--host", "0.0.0.0", "--port", "8080"]
